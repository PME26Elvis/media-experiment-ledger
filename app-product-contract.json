{
  "schema_version": 1,
  "contract_version": "2026-07-22.1",
  "product_line": {
    "name": "Media Experiment Ledger Desktop",
    "branch": "app-main",
    "status": "specification_in_progress",
    "implementation_status": "not_started",
    "default_user_language": "zh-TW",
    "secondary_user_language": "en",
    "local_first": true,
    "cross_platform": [
      "windows-x64",
      "macos-arm64",
      "macos-x64-provisional",
      "linux-x64"
    ],
    "default_merge_method": "merge",
    "delete_branches_by_default": false
  },
  "specification": {
    "index": "docs/app/README.md",
    "decision_log": "docs/app/DECISIONS.md",
    "open_questions": "docs/app/OPEN_QUESTIONS.md",
    "status_values": [
      "accepted",
      "provisional",
      "open",
      "rejected"
    ],
    "normative_terms": [
      "MUST",
      "SHOULD",
      "MAY",
      "MUST NOT"
    ]
  },
  "frontend": {
    "framework": "Vue 3",
    "component_library": "Vuetify 3",
    "component_api": "Composition API",
    "sfc_script": "<script setup lang=\"ts\">",
    "typescript_strict": true,
    "responsive_grid_required": true,
    "responsive_grid_components": [
      "v-container",
      "v-row",
      "v-col"
    ],
    "hover_required_for_interactive_surfaces": true,
    "hover_component": "v-hover",
    "transitions_required": true,
    "reduced_motion_required": true,
    "semantic_color_and_icon_required": true,
    "desktop_only_fixed_layout_prohibited": true
  },
  "desktop_security": {
    "node_integration": false,
    "context_isolation": true,
    "sandbox_renderer": true,
    "remote_module": false,
    "preload_allowlist_only": true,
    "validate_all_ipc_payloads": true,
    "renderer_direct_filesystem_access": false,
    "renderer_direct_secret_access": false,
    "renderer_direct_process_spawn": false,
    "external_navigation_default": "deny",
    "content_security_policy_required": true,
    "signed_update_required_for_automatic_install": true
  },
  "storage": {
    "project_manifest_format": "JSON",
    "project_database": "SQLite",
    "user_editable_config_primary_format": "YAML",
    "user_editable_config_supported_import_formats": [
      "yaml",
      "yml",
      "json",
      "toml"
    ],
    "config_export_formats": [
      "yaml",
      "json"
    ],
    "secrets_stored_in_plaintext_project_files": false,
    "env_file_is_secret_source": true,
    "env_file_export_includes_secret_values_by_default": false,
    "credentials_backend": "Electron safeStorage with OS credential provider",
    "credentials_portable_export_default": false,
    "atomic_writes_required": true,
    "schema_versioning_required": true,
    "migration_journal_required": true
  },
  "project_paths": {
    "image_input_independent": true,
    "video_input_independent": true,
    "atlas_output_independent": true,
    "detection_output_independent": true,
    "generated_media_output_independent": true,
    "all_paths_browsable": true,
    "all_paths_have_reasonable_defaults": true,
    "open_folder_action_required": true,
    "drag_drop_files_required": true,
    "drag_drop_directory_resolution_required": true,
    "portable_relative_paths_supported": true,
    "external_absolute_paths_supported": true,
    "missing_path_relink_workflow_required": true
  },
  "modules": {
    "workspace_home": {
      "status": "accepted",
      "route": "/workspace"
    },
    "media_import": {
      "status": "accepted",
      "route": "/import"
    },
    "api_automation": {
      "status": "accepted",
      "route": "/automation",
      "optional_for_all_users": true,
      "initial_provider": "Agnes",
      "media_types": [
        "image",
        "video"
      ]
    },
    "atlas_studio": {
      "status": "accepted",
      "route": "/atlas",
      "independent_job_domain": true,
      "pdf_export_static_images_only_v1": true,
      "editable_document_layout": true
    },
    "detection_studio": {
      "status": "accepted",
      "route": "/detection",
      "independent_job_domain": true,
      "multi_model": true,
      "resumable_jobs": true
    },
    "settings_and_secrets": {
      "status": "accepted",
      "route": "/settings"
    },
    "model_manager": {
      "status": "accepted",
      "route": "/models"
    },
    "job_center": {
      "status": "accepted",
      "route": "/jobs"
    },
    "report_library": {
      "status": "accepted",
      "route": "/reports"
    },
    "update_center": {
      "status": "accepted",
      "route": "/updates"
    }
  },
  "api_automation": {
    "provider_plugin_architecture": true,
    "agnes_image_initial_support": true,
    "agnes_video_initial_support": true,
    "api_key_optional": true,
    "multiple_credentials_per_provider": true,
    "credential_rotation_policy": true,
    "request_interval_policy": true,
    "concurrency_policy": true,
    "retry_policy": true,
    "rate_limit_policy": true,
    "stop_conditions": true,
    "budget_guards": true,
    "circuit_breaker": true,
    "pause_resume": true,
    "crash_recovery": true,
    "request_response_audit_without_secrets": true,
    "raw_provider_response_retention_configurable": true
  },
  "atlas": {
    "existing_web_implementation_is_not_complete_app_spec": true,
    "image_video_cohorts_separate": true,
    "full_corpus_jobs": true,
    "incremental_preview_allowed": true,
    "source_media_immutable": true,
    "editable_copy_for_document_layout": true,
    "rich_text_features": [
      "font_family",
      "font_size",
      "font_weight",
      "italic",
      "underline",
      "alignment",
      "color",
      "line_height",
      "spacing",
      "heading_style",
      "caption_style"
    ],
    "document_templates_required": true,
    "undo_redo_required": true,
    "autosave_required": true,
    "pdf_export": {
      "status": "accepted",
      "static_images_only_v1": true,
      "gif_animation_in_pdf": false,
      "gif_fallback": "selected poster frame or contact sheet",
      "print_preview_required": true,
      "page_break_control_required": true,
      "font_embedding_validation_required": true,
      "deterministic_export_manifest_required": true
    }
  },
  "detection": {
    "initial_model_families": [
      "YOLOX",
      "NanoDet-Plus"
    ],
    "initial_required_models": [
      "YOLOX-Tiny",
      "NanoDet-Plus-m-320"
    ],
    "candidate_models_pending_artifact_license_review": [
      "YOLOX-Nano",
      "YOLOX-S",
      "YOLOX-M",
      "YOLOX-L",
      "YOLOX-X",
      "NanoDet-Plus-m-416",
      "NanoDet-Plus-m-1.5x-320",
      "NanoDet-Plus-m-1.5x-416"
    ],
    "model_artifact_distribution": "open",
    "model_registry_required": true,
    "model_hash_verification_required": true,
    "license_manifest_required": true,
    "download_on_demand_supported": true,
    "user_supplied_model_supported_provisional": true,
    "progress_levels": [
      "job",
      "stage",
      "item"
    ],
    "checkpoint_granularity": "completed item plus durable stage metadata",
    "pause_resume": true,
    "cancel_with_partial_results": true,
    "crash_recovery": true,
    "retry_failed_items": true,
    "comparison_without_ground_truth_is_not_accuracy": true
  },
  "performance": {
    "design_corpus_images": 10000,
    "design_corpus_videos": 1000,
    "renderer_must_not_decode_full_corpus_eagerly": true,
    "virtualized_collections_required": true,
    "thumbnail_pyramid_required": true,
    "display_pixel_aware_preview_selection": true,
    "background_workers_required": true,
    "bounded_memory_caches_required": true,
    "database_pagination_required": true,
    "incremental_indexing_required": true,
    "main_thread_blocking_limit_ms": 50,
    "long_task_telemetry_required": true,
    "thumbnail_generation_resumable": true
  },
  "releases": {
    "app_tag_pattern": "desktop-v<semver>",
    "mock_data_tag_strategy": "same app Release by default; dedicated data Release allowed when size or cadence requires it",
    "mock_data_asset_prefix": "mel-sample-corpus",
    "mock_data_asset_examples": [
      "mel-sample-corpus-images-v1-part001.zip",
      "mel-sample-corpus-images-v1-part002.zip",
      "mel-sample-corpus-videos-v1-part001.zip"
    ],
    "mock_data_part_max_bytes": 1900000000,
    "mock_data_manifest_required": true,
    "mock_data_checksums_required": true,
    "raw_personal_data_review_required": true,
    "app_assets": [
      "windows-installer",
      "windows-portable-provisional",
      "macos-arm64",
      "macos-x64-provisional",
      "linux-appimage",
      "linux-deb-provisional"
    ],
    "manual_workflow_dispatch": true,
    "optional_release_notes_input": true,
    "optional_feature_list_input": true,
    "feature_list_markdown_bullets": true,
    "draft_prerelease_final_controls": true,
    "checksums_and_manifest_required": true
  },
  "updates": {
    "automatic_online_updates": true,
    "offline_update_package_import": true,
    "platform_specific_install_flow_required": true,
    "settings_preserved": true,
    "projects_preserved": true,
    "credential_migration_required": true,
    "pre_migration_backup_required": true,
    "transactional_migrations_required": true,
    "rollback_or_recovery_path_required": true,
    "downgrade_not_implicitly_supported": true,
    "linux_builtin_auto_update": "not_assumed",
    "manual_download_fallback_required": true
  },
  "quality": {
    "unit_tests": true,
    "component_tests": true,
    "ipc_contract_tests": true,
    "migration_tests": true,
    "large_corpus_benchmarks": true,
    "cross_platform_smoke": true,
    "signed_release_validation": true,
    "accessibility_tests": true,
    "reduced_motion_tests": true,
    "offline_mode_tests": true,
    "crash_recovery_tests": true,
    "release_asset_install_tests": true
  },
  "explicit_non_goals_v1": [
    "cloud account service operated by this repository",
    "mandatory API usage",
    "training object-detection models",
    "collaborative multi-user editing",
    "animated GIF preservation inside PDF",
    "mobile-native application",
    "silent execution of untrusted project scripts",
    "claiming detector accuracy on unlabeled generated media"
  ]
}