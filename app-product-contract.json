      "MUST",
      "SHOULD",
      "MAY",
      "MUST NOT"
    ]
  },
  "frontend": {
    "framework": "Vue 3",
    "component_library": "Vuetify 3",
    "component_api": "Composition API",
    "sfc_script": "<script setup lang=\"ts\">",
