    "settings_and_secrets": {
      "status": "accepted",
      "route": "/settings"
    },
    "model_manager": {
      "status": "accepted",
      "route": "/models"
    },
    "job_center": {
      "status": "accepted",
      "route": "/jobs"
    },
    "report_library": {
      "status": "accepted",
      "route": "/reports"
    },
    "update_center": {
      "status": "accepted",
      "route": "/updates"
    }
