{
  "schema_version": 1,
  "contract_version": "2026-07-21.2",
  "default_user_language": "zh-TW",
  "repository": {
    "formal_release_pattern": "^media-exp-\\d{4}-\\d{2}-\\d{2}(?:-s\\d{2})?$",
    "transport_release_pattern": "^media-input-",
    "formal_source_of_truth": "immutable media-exp-* Releases after applying the versioned quarantine policy",
    "quarantine_file": "config/release-quarantine.json",
    "historical_correction_policy": "preserve historical assets; quarantine invalid runs, regenerate derived data, and repair managed Release Notes",
    "default_merge_method": "merge",
    "delete_branches_by_default": false
  },
  "pages": {
    "workflow_path": ".github/workflows/analytics.yml",
    "build_output": "site/",
    "build_output_tracked": false,
    "deployment_transport": "actions/upload-pages-artifact",
    "build_deploy_writeback_separate": true,
    "deployment_independent_of_writeback": true,
    "writeback_paths": ["analytics/", "forecasts/"],
    "writeback_rebase_retries": 3,
    "primary_routes": [
      "overview",
      "analytics",
      "visual-lab",
      "detector-lab",
      "yolo-lab",
      "forecast",
      "architecture",
      "frontend-stack"
    ],
    "deployed_json_artifacts": [
      "data/analytics.json",
      "data/forecast.json",
      "data/visual-analysis.json",
      "data/detection/latest.json",
      "data/yolo/latest.json"
    ],
    "max_total_bytes": 1000000000,
    "max_single_file_bytes": 100000000
  },
  "atlas": {
    "scope": "all published, non-quarantined media-exp-* runs",
    "hidden_incremental_state": false,
    "release_assets_zip_only": true,
    "image_video_cohorts_separate": true,
    "prompts_per_bundle": 15,
    "video_seed_is_evidence_not_identity": true,
    "history_overrides_file": "config/atlas-history-overrides.json",
    "history_metric_policy": "audited authoritative override only for a proven corrupt legacy report; otherwise explicit immutable Atlas report value, then non-authoritative missing-field override, otherwise unknown; never current corpus totals",
    "yolo_independence": "YOLO and detector comparison workflows must not change, gate, share a finalizer with, or publish assets into the Atlas workflow or media-analysis-* Releases",
    "release_notes": {
      "image_max": 15,
      "image_min_unique_samples": 4,
      "image_selection": "strongest cohort per category first, then descending unique sample count with deterministic tie-breaking",
      "video_mode": "all",
      "video_min_unique_samples": 2,
      "sections": ["Image highlights", "Video highlights"]
    }
  },
  "experiment_integrity": {
    "completed_event_counts_must_match_archived_media_counts": true,
    "empty_runs_are_not_publishable": true,
    "production_run_id_pattern": "^run_\\d{8}_\\d{6}(?:_[A-Za-z0-9][A-Za-z0-9._-]*)?$",
    "audit_report_json": "data/audits/experiment-releases.json",
    "audit_report_markdown": "docs/reports/EXPERIMENT_RELEASE_AUDIT.md"
  },
  "planned_analysis": {
    "yolo_object_detection": {
      "status": "implemented",
      "production_release": "media-yolo-all-2026-07-13-v1",
      "production_writeback_commit": "bab357c4f92963d5d74e7229ad86272147436295",
      "production_canonical_images": 387,
      "production_images_with_detections": 313,
      "production_total_detections": 1533,
      "spec": "docs/YOLO_OBJECT_DETECTION_SPEC.md",
      "default_model_family": "YOLOX-Tiny",
      "runtime": "ONNX Runtime CPU",
      "training_dataset": "COCO 80 classes",
      "license": "Apache-2.0",
      "workflow_path": ".github/workflows/yolo-object-detection.yml",
      "workflow_mode": "legacy manual recovery only after multi-detector cutover",
      "release_pattern": "^media-yolo-all-\\d{4}-\\d{2}-\\d{2}-v\\d+$",
      "release_strategy": "immutable historical media-yolo-* family; new production detector publications use media-detection-*",
      "atlas_coupling": "none",
      "default_execution_plan": "one full GitHub-hosted CPU job",
      "design_corpus_images": 3000,
      "job_timeout_minutes": 350,
      "matrix_sharding_v1": false,
      "rebuild_policy": "every invocation reprocesses the complete canonical image corpus from scratch",
      "persistent_state": false,
      "cross_run_cache_skip": false,
      "published_result_reuse": false,
      "visual_lab_join_key": "image_sha256",
      "implementation_entrypoint": "tools/build_yolo_detection.py",
      "requirements": "requirements-yolo.txt",
      "model_lock": "object-detection/model-lock.json",
      "labels": "object-detection/coco-80.json",
      "latest_index": "data/yolo/latest.json",
      "history_index": "data/yolo/history.json",
      "web_index": "web/public/data/yolo/latest.json",
      "visual_lab_route": "yolo-lab",
      "release_notes_preview_max": 20
    },
    "multi_detector_yolox_nanodet": {
      "status": "implemented_pending_production",
      "spec": "docs/NANODET_MULTI_DETECTOR_PIPELINE_SPEC.md",
      "detectors": ["YOLOX-Tiny", "NanoDet-Plus-m-320"],
      "inference_workflows": [
        ".github/workflows/detector-yolox-inference.yml",
        ".github/workflows/detector-nanodet-inference.yml"
      ],
      "publisher_workflow": ".github/workflows/detector-comparison-publish.yml",
      "release_pattern": "^media-detection-all-\\d{4}-\\d{2}-\\d{2}-v\\d+$",
      "artifact_pairing": "exact workflow run IDs plus identical analysis_batch_id, corpus fingerprint, quarantine digest, source Releases, canonical image SHA set, labels, and thresholds",
      "artifact_role": "short-lived transport only; not a source of truth or inference cache",
      "publisher_initial_mode": "manual exact run-ID inputs plus safe same-head-sha workflow_run pairing",
      "comparison_language": "agreement and disagreement only; never accuracy without ground truth",
      "atlas_coupling": "none",
      "persistent_state": false,
      "cross_run_cache_skip": false,
      "published_result_reuse": false,
      "comparison_gallery": "original, YOLOX-Tiny, and NanoDet-Plus tri-panel plus offline HTML ZIP",
      "nanodet_runtime": "ONNX Runtime CPU",
      "nanodet_model_lock": "object-detection/nanodet-model-lock.json",
      "nanodet_requirements": "requirements-nanodet.txt",
      "nanodet_model_smoke": "tools/nanodet_model_smoke.py",
      "artifact_builder": "tools/build_detector_artifact.py",
      "publisher_entrypoint": "tools/publish_detector_comparison.py",
      "latest_index": "data/detection/latest.json",
      "history_index": "data/detection/history.json",
      "web_index": "web/public/data/detection/latest.json",
      "detector_lab_route": "detector-lab",
      "release_notes_preview_max": 20,
      "production_release": null,
      "production_yolox_run_id": null,
      "production_nanodet_run_id": null,
      "production_publisher_run_id": null,
      "production_writeback_commit": null
    }
  },
  "required_validation": [
    "python tools/validate_project_contract.py",
    "python -m compileall tools tests",
    "python -m unittest discover -s tests -v",
    "python tools/yolo_model_smoke.py",
    "python tools/nanodet_model_smoke.py",
    "npm run build --prefix web",
    "python tools/validate_site_build.py"
  ],
  "synchronized_surfaces": [
    "README.md", "README.en.md", "AGENTS.md", "docs/PROJECT_CONTRACT.md",
    "docs/ANALYTICS_AND_PAGES.md", "docs/WEB_EXPERIENCE_AND_FORECASTS.md",
    "docs/PROMPT_REPEATABILITY_ATLAS.md", "docs/VIDEO_REPEATABILITY_ATLAS.md",
    "docs/YOLO_OBJECT_DETECTION_SPEC.md", "docs/NANODET_MULTI_DETECTOR_PIPELINE_SPEC.md",
    "visual-analysis/config.json", "config/release-quarantine.json",
    "config/atlas-history-overrides.json", ".gitignore",
    ".github/workflows/analytics.yml", ".github/workflows/validate.yml",
    ".github/workflows/yolo-object-detection.yml",
    ".github/workflows/detector-yolox-inference.yml",
    ".github/workflows/detector-nanodet-inference.yml",
    ".github/workflows/detector-comparison-publish.yml",
    "tools/validate_site_build.py", "requirements-yolo.txt", "requirements-nanodet.txt",
    "object-detection/model-lock.json", "object-detection/nanodet-model-lock.json",
    "object-detection/coco-80.json", "tools/yolo_core.py", "tools/yolo_corpus.py",
    "tools/yolo_packages.py", "tools/yolo_publish.py", "tools/build_yolo_detection.py",
    "tools/yolo_model_smoke.py", "tools/nanodet_core.py", "tools/prepare_nanodet_model.py",
    "tools/nanodet_model_smoke.py", "tools/build_detector_artifact.py",
    "tools/publish_detector_comparison.py", "data/yolo/latest.json", "data/yolo/history.json",
    "web/public/data/yolo/latest.json", "data/detection/latest.json", "data/detection/history.json",
    "web/public/data/detection/latest.json", "web/src/components/YoloLab.astro",
    "web/src/content/docs/yolo-lab.mdx", "web/src/components/DetectorLab.astro",
    "web/src/content/docs/detector-lab.mdx", "web/navigation.mjs", "tests"
  ]
}
