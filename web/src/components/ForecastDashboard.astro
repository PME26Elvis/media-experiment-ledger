<section class="dashboard-shell forecast-shell" data-forecast-dashboard>
  <div class="forecast-hero panel-surface">
    <div>
      <span class="eyebrow">ENSEMBLE INTELLIGENCE</span>
      <h2>Forecast Lab</h2>
      <p>Rolling-origin model selection, residual-bootstrap intervals, and 10,000-path monthly simulations.</p>
    </div>
    <div class="confidence-orb" data-confidence><span>—</span><small>confidence</small></div>
  </div>
  <div class="metric-grid" data-forecast-metrics></div>
  <div class="bento-grid">
    <article class="panel-surface span-8"><div class="panel-title"><span>Next active-day forecast</span><small>History, ensemble point, and 80% interval</small></div><div class="chart-xl" data-chart="forecast-history"></div></article>
    <article class="panel-surface span-4"><div class="panel-title"><span>Operating regime</span><small>Recent trend and volatility classification</small></div><div class="regime-card" data-regime></div></article>
    <article class="panel-surface span-5"><div class="panel-title"><span>Next month simulation</span><small data-month-label>10,000 Monte Carlo paths</small></div><div class="monthly-forecast" data-monthly></div></article>
    <article class="panel-surface span-7"><div class="panel-title"><span>Model arena</span><small>Cross-validated weight allocation</small></div><div class="chart-md" data-chart="model-weights"></div></article>
  </div>
  <article class="panel-surface">
    <div class="panel-title"><span>Model leaderboard</span><small>Lower MAE is better; weights are target-specific</small></div>
    <div class="table-scroll"><table class="data-table"><thead><tr><th>Target</th><th>Model</th><th>Weight</th><th>MAE</th><th>Backtest folds</th></tr></thead><tbody data-model-table></tbody></table></div>
  </article>
  <p class="dashboard-status" data-status>Loading forecast artifacts…</p>
</section>

<script>
  import * as echarts from 'echarts';
  const root = document.querySelector('[data-forecast-dashboard]');
  if (root) {
    const base = import.meta.env.BASE_URL;
    const fmt = (value, kind) => kind === 'rate' ? `${(value * 100).toFixed(1)}%` : kind === 'positive' ? `${value.toFixed(1)}s` : new Intl.NumberFormat().format(Math.round(value));
    const targetColors = { runs: '#9d7cff', image_completed: '#52d3ff', video_completed: '#5ee6a8', errors: '#ff7b9c', success_rate: '#ffd166', latency_mean_s: '#ff9f5a' };
    try {
      const response = await fetch(`${base}data/forecast.json`, { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      const confidence = data.confidence || {};
      root.querySelector('[data-confidence]').innerHTML = `<span>${confidence.score ?? 0}</span><small>${confidence.label || 'pending'}</small>`;
      const dateInfo = data.next_active_day?.date || {};
      const targets = data.next_active_day?.targets || {};
      root.querySelector('[data-forecast-metrics]').innerHTML = Object.entries(targets).slice(0, 6).map(([key, target]) => `<article class="metric-card forecast"><span>${target.label}</span><strong>${fmt(target.point, target.kind)}</strong><small>${fmt(target.lower_80, target.kind)} – ${fmt(target.upper_80, target.kind)}</small></article>`).join('');

      const regime = data.regime || {};
      root.querySelector('[data-regime]').innerHTML = `<div class="regime-badge ${regime.tone || 'neutral'}">${regime.label || 'Pending'}</div><dl><div><dt>Output delta</dt><dd>${(regime.output_delta || 0).toFixed(1)}</dd></div><div><dt>Success delta</dt><dd>${((regime.success_delta || 0) * 100).toFixed(1)} pp</dd></div><div><dt>Volatility</dt><dd>${(regime.coefficient_of_variation || 0).toFixed(2)}</dd></div><div><dt>Recent errors</dt><dd>${(regime.recent_mean_errors || 0).toFixed(1)}</dd></div></dl><p>${confidence.note || ''}</p>`;

      const month = data.next_month || {};
      root.querySelector('[data-month-label]').textContent = `${month.period || 'Next month'} · 10,000 Monte Carlo paths`;
      const monthRows = [['Active days', month.active_days], ['Runs', month.runs], ['Images', month.images], ['Videos', month.videos], ['Errors', month.errors], ['Success', month.success_rate]];
      root.querySelector('[data-monthly]').innerHTML = monthRows.filter(([, value]) => value).map(([label, value]) => `<div><span>${label}</span><strong>${label === 'Success' ? `${(value.median*100).toFixed(1)}%` : Math.round(value.median)}</strong><small>${label === 'Success' ? `${(value.lower_80*100).toFixed(1)}–${(value.upper_80*100).toFixed(1)}%` : `${Math.round(value.lower_80)}–${Math.round(value.upper_80)}`}</small></div>`).join('');

      const selectedKeys = ['image_completed', 'video_completed', 'success_rate', 'errors'];
      const allDates = [...new Set(selectedKeys.flatMap(key => (targets[key]?.history || []).map(point => point.date)))].sort();
      const forecastDate = dateInfo.point_date || 'forecast';
      const chart = echarts.init(root.querySelector('[data-chart="forecast-history"]'));
      const series = [];
      for (const key of selectedKeys) {
        const target = targets[key];
        if (!target) continue;
        const historyMap = Object.fromEntries(target.history.map(point => [point.date, point.value]));
        const historical = allDates.map(date => historyMap[date] ?? null);
        historical.push(null);
        const forecastLine = allDates.map(() => null);
        forecastLine.push(target.point);
        series.push({ name: target.label, type: 'line', smooth: true, symbolSize: 7, data: historical, lineStyle: { width: 2.5, color: targetColors[key] }, itemStyle: { color: targetColors[key] } });
        series.push({ name: `${target.label} forecast`, type: 'scatter', symbolSize: 16, data: forecastLine, itemStyle: { color: targetColors[key], borderColor: '#fff', borderWidth: 2 }, tooltip: { valueFormatter: value => fmt(value, target.kind) } });
        series.push({ name: `${target.label} 80% interval`, type: 'custom', coordinateSystem: 'cartesian2d', renderItem: (params, api) => { const x = api.coord([api.value(0), api.value(1)])[0]; const low = api.coord([api.value(0), api.value(1)])[1]; const high = api.coord([api.value(0), api.value(2)])[1]; return { type: 'group', children: [{ type: 'line', shape: { x1: x, y1: low, x2: x, y2: high }, style: { stroke: targetColors[key], lineWidth: 5, opacity: .45 } }, { type: 'line', shape: { x1: x-7, y1: low, x2: x+7, y2: low }, style: { stroke: targetColors[key], lineWidth: 2 } }, { type: 'line', shape: { x1: x-7, y1: high, x2: x+7, y2: high }, style: { stroke: targetColors[key], lineWidth: 2 } }] }; }, data: [[allDates.length, target.lower_80, target.upper_80]], silent: true, z: 1 });
      }
      chart.setOption({
        animationDuration: 900,
        tooltip: { trigger: 'axis', backgroundColor: 'rgba(6,15,28,.95)', borderColor: '#294760', textStyle: { color: '#eef7ff' } },
        legend: { top: 0, type: 'scroll', textStyle: { color: '#b9cae0' }, selected: Object.fromEntries(series.filter(s => s.name.includes('80%')).map(s => [s.name, false])) },
        toolbox: { right: 8, feature: { dataZoom: {}, restore: {}, saveAsImage: { pixelRatio: 2 } } },
        grid: { left: 55, right: 30, top: 70, bottom: 65 },
        xAxis: { type: 'category', data: [...allDates, forecastDate], axisLabel: { rotate: 30, color: '#9db0c7' } },
        yAxis: { type: 'value', scale: true, axisLabel: { color: '#9db0c7' }, splitLine: { lineStyle: { color: 'rgba(116,150,184,.15)' } } },
        dataZoom: [{ type: 'inside' }, { type: 'slider', height: 16, bottom: 8 }],
        series
      });

      const arenaRows = [];
      for (const [targetKey, models] of Object.entries(data.model_arena || {})) {
        for (const model of models) arenaRows.push({ targetKey, target: targets[targetKey]?.label || targetKey, ...model });
      }
      root.querySelector('[data-model-table]').innerHTML = arenaRows.sort((a,b) => b.weight-a.weight).map(row => `<tr><td>${row.target}</td><td>${row.model}</td><td>${(row.weight*100).toFixed(1)}%</td><td>${row.mae.toFixed(3)}</td><td>${row.folds}</td></tr>`).join('');
      const topModels = arenaRows.sort((a,b) => b.weight-a.weight).slice(0, 16);
      const weightsChart = echarts.init(root.querySelector('[data-chart="model-weights"]'));
      weightsChart.setOption({ tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } }, grid: { left: 120, right: 25, top: 20, bottom: 35 }, xAxis: { type: 'value', max: 1, axisLabel: { formatter: value => `${value*100}%`, color: '#9db0c7' } }, yAxis: { type: 'category', data: topModels.map(row => `${row.target} · ${row.model}`), axisLabel: { color: '#9db0c7', width: 110, overflow: 'truncate' } }, series: [{ type: 'bar', data: topModels.map(row => ({ value: row.weight, itemStyle: { color: targetColors[row.targetKey] || '#52d3ff', borderRadius: [0,7,7,0] } })) }] });
      window.addEventListener('resize', () => { chart.resize(); weightsChart.resize(); });
      root.querySelector('[data-status]').textContent = `Generated ${data.generated_at_utc ? new Date(data.generated_at_utc).toLocaleString() : 'when analytics last ran'} · next active date window ${dateInfo.earliest_date || '—'} to ${dateInfo.latest_date || '—'}`;
    } catch (error) {
      root.querySelector('[data-status]').textContent = `Forecast artifacts could not be loaded: ${String(error)}`;
      root.querySelector('[data-status]').classList.add('error');
    }
  }
</script>
