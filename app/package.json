{
  "name": "media-experiment-ledger-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Atlas, object detection and media automation studio",
  "main": "dist/main/main/main.js",
  "license": "Apache-2.0",
  "engines": { "node": ">=22.12.0 <23" },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist/main/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run clean && npm run typecheck && npm run build:main && npm run build:renderer",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "engine:test": "python -m unittest discover -s engine/tests -p 'test_*.py'",
    "engine:build": "python scripts/build_engine.py",
    "package": "npm run build && npm run engine:build && electron-builder --dir --publish never",
    "dist": "npm run build && npm run engine:build && electron-builder"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@noble/ciphers": "2.2.0",
    "@tanstack/vue-query": "5.101.3",
    "electron-updater": "6.8.9",
    "hash-wasm": "4.12.0",
    "pinia": "4.0.2",
    "vue": "3.5.40",
    "vue-i18n": "11.4.6",
    "vue-router": "4.6.3",
    "vuetify": "3.12.10",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "22.18.12",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/test-utils": "2.4.6",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "happy-dom": "20.11.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.1.10",
    "vue-tsc": "3.1.1",
    "wait-on": "8.0.4"
  },
  "build": {
    "appId": "io.github.pme26elvis.media-experiment-ledger-studio",
    "productName": "Media Experiment Ledger Studio",
    "asar": true,
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "package.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "extraResources": [
      { "from": "engine-bin", "to": "engine-bin", "filter": ["**/*"] },
      { "from": "resources/update-public-key.pem", "to": "update-public-key.pem" },
      { "from": "../app-product-contract.json", "to": "app-product-contract.json" }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
    },
    "mac": {
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Graphics"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PME26Elvis",
        "repo": "media-experiment-ledger"
      }
    ]
  }
}
